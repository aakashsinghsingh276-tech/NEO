
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Information about the registered user.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email"]
    },
    "File": {
      "title": "File",
      "description": "A code file or folder within a user's workspace.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "path": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["file", "folder"] },
        "parentId": { "type": "string" },
        "updatedAt": { "type": "object" }
      },
      "required": ["name", "type"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Individual user profiles."
    },
    "/users/{userId}/files/{fileId}": {
      "schema": "File",
      "description": "User specific workspace files and folders."
    }
  }
}
