
{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A workspace project containing files and settings.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "ownerId": { "type": "string" }
      },
      "required": ["name", "ownerId"]
    },
    "File": {
      "title": "File",
      "description": "A code file within a project.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "path": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["file", "folder"] },
        "parentId": { "type": "string" }
      },
      "required": ["name", "type"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of projects."
    },
    "/projects/{projectId}/files/{fileId}": {
      "schema": "File",
      "description": "Files and folders within a project."
    }
  }
}
